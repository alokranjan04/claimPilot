# ClaimPilot — environment variables
# Copy this to .env and fill in the values for your environment.
# .env is gitignored and must never be committed.
#
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEV with real Azure services (PROVIDER=azure + API keys)
# ──────────────────────────────────────────────────────────────────────────────
#
# Run offline with deterministic fakes (default — no keys needed):
#   PROVIDER=fake
#
# Run against real Azure (fill in the values below, then):
#   PROVIDER=azure

PROVIDER=fake

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Portal: Azure OpenAI resource → Keys and Endpoint
AOAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AOAI_API_KEY=<key1-or-key2-from-portal>
AOAI_DEPLOYMENT_CHAT=gpt-4o
AOAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small
AOAI_API_VERSION=2024-02-01

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Portal: AI Search resource → Keys → Admin keys
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<admin-key-from-portal>
AZURE_SEARCH_INDEX=claimpilot-chunks
AZURE_SEARCH_SEMANTIC_CONFIG=claimpilot-semantic

# ── Azure Document Intelligence ───────────────────────────────────────────────
# Portal: Document Intelligence resource → Keys and Endpoint
AZURE_DOCINTEL_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
AZURE_DOCINTEL_API_KEY=<key1-or-key2-from-portal>

# ── Azure Service Bus ─────────────────────────────────────────────────────────
# Portal: Service Bus namespace → Shared access policies → RootManageSharedAccessKey
# Either set the full connection string (easy for local dev):
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
# Or set just the namespace (uses DefaultAzureCredential — requires az login or MI):
# AZURE_SERVICEBUS_NAMESPACE=<namespace>.servicebus.windows.net
AZURE_SERVICEBUS_QUEUE=claims

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Portal: Cosmos DB account → Keys → PRIMARY KEY
AZURE_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
AZURE_COSMOS_KEY=<primary-key-from-portal>
AZURE_COSMOS_DATABASE=claimpilot
AZURE_COSMOS_CONTAINER=checkpoints

# ── Azure Monitor / Application Insights ──────────────────────────────────────
# Portal: Application Insights resource → Overview → Connection String
AZURE_MONITOR_CONNECTION_STRING=InstrumentationKey=<guid>;IngestionEndpoint=https://...

# ──────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Managed Identity — leave all *_API_KEY / *_KEY / *_CONNECTION_STRING
# fields empty or unset; DefaultAzureCredential handles auth automatically)
# ──────────────────────────────────────────────────────────────────────────────
# PROVIDER=azure
# AOAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
# AZURE_DOCINTEL_ENDPOINT=https://<your-docintel>.cognitiveservices.azure.com/
# AZURE_SERVICEBUS_NAMESPACE=<namespace>.servicebus.windows.net
# AZURE_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
# AZURE_MONITOR_CONNECTION_STRING=InstrumentationKey=...
